generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  WORKER
}

enum DealStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum OperationType {
  PURCHASE
  ATM
  TRANSFER
}

enum FieldType {
  TEXT
  NUMBER
  SELECT
  DATE
  PERCENT
  CHECKBOX
  CURRENCY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  deals         Deal[]
  expenses      Expense[]
  dealTemplates DealTemplate[]
  memberships   UserMembership[]
  tasks         Task[]
  chatMessages  ChatMessage[] @relation("OrgMessages")
  salaryPayments SalaryPayment[]
}

model User {
  id              String   @id @default(cuid())
  email           String
  passwordHash    String
  role            Role     @default(MANAGER)
  position        String?
  name            String?
  phone           String?
  telegram        String?
  contacts        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  dealParticipants   DealParticipant[]
  sessions           Session[]
  memberships        UserMembership[]
  passwordResetTokens PasswordResetToken[]
  tasksAssigned        Task[]         @relation("TaskAssignee")
  tasksCreated         Task[]         @relation("TaskCreator")
  taskComments      TaskComment[]
  sentMessages      ChatMessage[] @relation("MsgSender")
  receivedMessages  ChatMessage[] @relation("MsgReceiver")
  chatReadAs        ChatLastRead[] @relation("ChatReader")
  chatReadOther     ChatLastRead[] @relation("ChatOther")
  auditLogs         AuditLog[]
  salaryConfig      EmployeeSalaryConfig?
  salaryPayments    SalaryPayment[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())

  ip        String?
  userAgent String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@index([userId])
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String   // LOGIN, LOGOUT, CREATE_DEAL, UPDATE_DEAL, etc.
  entityType     String?  // deal | client | expense | task | user | session
  entityId       String?
  details        Json?    // snapshot of what changed
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?

  @@index([userId])
  @@index([organizationId, createdAt])
  @@index([createdAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  deals Deal[]

  @@index([organizationId])
  @@unique([organizationId, phone])
}

model Deal {
  id        String   @id @default(cuid())
  title     String
  status    DealStatus @default(NEW)
  dealDate  DateTime @default(now())
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  amounts       DealAmount[]
  participants  DealParticipant[]
  dataRows      DealDataRow[]

  templateId    String?
  template      DealTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
  @@index([templateId])
}

model DealTemplate {
  id             String   @id @default(cuid())
  name           String
  hasWorkers     Boolean  @default(true)
  incomeFieldKey String?
  /// null | "MEDIATOR_AI_PAYROLL" — цепочка: посредник % → % ИИ от R1 → зарплатный фонд % от R2 → остаток офис
  calcPreset         String?
  payrollPoolPct     Decimal? @db.Decimal(5, 2)
  calcGrossFieldKey  String?
  calcMediatorPctKey String?
  calcAiPctKey       String?
  calcSteps          Json?    // Array<CalcStep> — universal calculation chain
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fields DealTemplateField[]
  deals  Deal[]

  @@index([organizationId])
}

model DealTemplateField {
  id         String    @id @default(cuid())
  templateId String
  template   DealTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String
  label      String
  type       FieldType @default(TEXT)
  required   Boolean   @default(false)
  order      Int       @default(0)
  options    String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([templateId, key])
  @@index([templateId])
}

model DealDataRow {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  data      Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([dealId])
}

model DealAmount {
  id            String        @id @default(cuid())
  amountIn      Decimal       @db.Decimal(18, 2)
  currencyIn    String
  amountOut     Decimal       @db.Decimal(18, 2)
  currencyOut   String
  bank          String
  operationType OperationType
  shopName      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model DealParticipant {
  id        String @id @default(cuid())
  pct       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([dealId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Extra org memberships — user can belong to multiple offices
model UserMembership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String
  payMethod String
  status    ExpenseStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus  @default(PENDING)
  startsAt       DateTime?
  dueAt          DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assigneeId     String
  assignee       User         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  createdById    String
  createdBy      User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  comments       TaskComment[]

  @@index([organizationId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ExchangeRate {
  code      String   @id         // "USD", "EUR", "UAH", "PLN", "CHF"
  symbol    String               // "$", "€", "₴", "zł", "Fr"
  name      String
  rateToUsd Decimal  @db.Decimal(18, 6)
  updatedAt DateTime @updatedAt
}

// Salary configuration per employee
model EmployeeSalaryConfig {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseAmount Decimal  @db.Decimal(18, 2) @default(0)  // monthly base salary
  currency   String   @default("USD")
  payDay     Int      @default(1)  // day of month 1-31
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum SalaryPaymentType {
  BASE       // базовая ставка
  DEAL_BONUS // бонус по сделкам
  ADVANCE    // аванс
  MANUAL     // ручная корректировка
}

// Individual salary payment records
model SalaryPayment {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amount         Decimal            @db.Decimal(18, 2)
  currency       String             @default("USD")
  period         String             // "2026-04" — month-year
  type           SalaryPaymentType  @default(MANUAL)
  note           String?
  isPaid         Boolean            @default(false)
  paidAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([period])
}

// Direct messages between two users in same org
model ChatMessage {
  id             String       @id @default(cuid())
  body           String       // AES-256-GCM encrypted: iv:authTag:ciphertext
  createdAt      DateTime     @default(now())

  organizationId String
  organization   Organization @relation("OrgMessages", fields: [organizationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User         @relation("MsgSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId     String
  receiver       User         @relation("MsgReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, senderId, createdAt])
}

// Tracks last-read timestamp per conversation pair
model ChatLastRead {
  lastReadAt   DateTime @default(now())

  userId       String
  user         User     @relation("ChatReader", fields: [userId], references: [id], onDelete: Cascade)

  otherUserId  String
  other        User     @relation("ChatOther", fields: [otherUserId], references: [id], onDelete: Cascade)

  @@id([userId, otherUserId])
}

