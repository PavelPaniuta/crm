generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

enum DealStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  clients Client[]
  deals   Deal[]
  expenses Expense[]
}

model User {
  id              String   @id @default(cuid())
  email           String
  passwordHash    String
  role            Role     @default(MANAGER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  dealParticipants DealParticipant[]
  sessions         Session[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@index([userId])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  deals Deal[]

  @@index([organizationId])
  @@unique([organizationId, phone])
}

model Deal {
  id        String   @id @default(cuid())
  title     String
  status    DealStatus @default(NEW)
  dealDate  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  amounts       DealAmount[]
  participants  DealParticipant[]

  @@index([organizationId])
  @@index([clientId])
}

model DealAmount {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(18, 2)
  currency  String
  mediatorPct Int @default(0)
  rateToUsdt Decimal @db.Decimal(18, 6)
  payoutUsdt Decimal @db.Decimal(18, 2)
  branchPct  Int @default(0)
  branchShareUsdt Decimal @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model DealParticipant {
  id        String @id @default(cuid())
  pct       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([dealId])
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String
  payMethod String
  status    ExpenseStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

